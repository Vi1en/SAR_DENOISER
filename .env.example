# Copy to .env for local API/async jobs (never commit .env).
# Streamlit demo works without these (sync inference only).

# Optional: store async job files outside repo
# SAR_JOBS_DIR=data/jobs

# Optional: FastAPI + Redis/RQ (not required for streamlit run demo/streamlit_app.py)
# REDIS_URL=redis://localhost:6379/0
# SAR_USE_QUEUE=0
